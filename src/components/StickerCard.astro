---
interface Props {
    class?: string;
    rotate?: boolean;
    rotateAmount?: number;
    hoverLift?: boolean;
    shine?: boolean;
    [x: string]: any;
}

const { 
    class: className, 
    rotate = false, 
    rotateAmount,
    hoverLift = true,
    shine = true,
    ...rest 
} = Astro.props;

// Intentional rotation based on index or provided amount
const rotation = rotateAmount !== undefined 
    ? rotateAmount 
    : rotate 
        ? (Math.random() > 0.5 ? 1.5 : -1.5) 
        : 0;
---

<div
    class:list={[
        "sticker-card",
        hoverLift ? "hover-lift" : "",
        shine ? "shine-effect" : "",
        className,
    ]}
    style={`--rotation: ${rotation}deg;`}
    {...rest}
>
    <slot />
</div>

<style>
    .sticker-card {
        transform: rotate(var(--rotation, 0deg));
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        position: relative;
        overflow: hidden;
    }
    
    .sticker-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.1) 0%,
            transparent 50%,
            rgba(0, 0, 0, 0.02) 100%
        );
        pointer-events: none;
        border-radius: inherit;
    }
    
    .hover-lift:hover {
        transform: rotate(0deg) translateY(-6px) scale(1.02);
        box-shadow: 
            8px 8px 0px 0px #1A1A1B,
            0 15px 30px -10px rgba(26, 26, 27, 0.2);
    }
    
    .shine-effect {
        position: relative;
        overflow: hidden;
    }
    
    .shine-effect::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
            to right,
            transparent 0%,
            rgba(255, 255, 255, 0.15) 50%,
            transparent 100%
        );
        transform: rotate(25deg) translateX(-100%);
        transition: transform 0.6s ease;
        pointer-events: none;
        border-radius: inherit;
    }
    
    .shine-effect:hover::after {
        transform: rotate(25deg) translateX(100%);
    }
</style>
