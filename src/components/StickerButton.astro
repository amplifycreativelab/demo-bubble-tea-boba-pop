---
interface Props {
    href?: string;
    variant?: "primary" | "secondary" | "accent" | "ink";
    class?: string;
    glow?: boolean;
    [x: string]: any;
}

const { href, variant = "primary", class: className, glow = true, ...rest } = Astro.props;

const variantClasses = {
    primary: "bg-primary text-ink",
    secondary: "bg-secondary text-ink",
    accent: "bg-accent text-ink",
    ink: "bg-ink text-white",
};

const Tag = href ? "a" : "button";
---

<Tag
    href={href}
    class:list={[
        "sticker-button",
        variantClasses[variant],
        glow ? "glow-effect" : "",
        className,
    ]}
    {...rest}
>
    <slot />
</Tag>

<style>
    .sticker-button {
        position: relative;
        isolation: isolate;
    }
    
    /* Animated background shimmer */
    .sticker-button::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.2),
            transparent
        );
        transform: translateX(-100%);
        transition: transform 0.5s ease;
        border-radius: inherit;
        z-index: -1;
    }
    
    .sticker-button:hover::before {
        transform: translateX(100%);
    }
    
    /* Glow effect on hover */
    .glow-effect.bg-primary:hover {
        box-shadow: 
            6px 6px 0px 0px #1A1A1B,
            0 0 25px rgba(255, 45, 171, 0.4),
            inset 0 0 20px rgba(255, 255, 255, 0.1);
    }
    
    .glow-effect.bg-secondary:hover {
        box-shadow: 
            6px 6px 0px 0px #1A1A1B,
            0 0 25px rgba(0, 240, 255, 0.4),
            inset 0 0 20px rgba(255, 255, 255, 0.1);
    }
    
    .glow-effect.bg-accent:hover {
        box-shadow: 
            6px 6px 0px 0px #1A1A1B,
            0 0 25px rgba(255, 240, 31, 0.4),
            inset 0 0 20px rgba(255, 255, 255, 0.1);
    }
    
    .glow-effect.bg-ink:hover {
        box-shadow: 
            6px 6px 0px 0px #1A1A1B,
            0 0 25px rgba(255, 45, 171, 0.3),
            inset 0 0 20px rgba(255, 255, 255, 0.05);
    }
</style>
