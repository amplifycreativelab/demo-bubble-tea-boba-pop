---
import { CupSoda, Sparkles } from "lucide-preact";
---

<div
    class="relative w-full max-w-lg mx-auto lg:ml-auto select-none"
    id="hero-cup-container"
>
    <!-- Atmospheric Background Blobs -->
    <div class="absolute -inset-10 pointer-events-none overflow-hidden">
        <div class="absolute top-1/4 left-1/4 w-40 h-40 bg-primary/20 rounded-full blur-3xl animate-pulse-slow"></div>
        <div class="absolute bottom-1/4 right-1/4 w-32 h-32 bg-secondary/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
    </div>
    
    <!-- Rotating seal badge: hand-shaken / fresh daily -->
    <div
        class="absolute -top-12 -left-12 w-28 h-28 md:w-32 md:h-32 float z-10 drop-shadow-[5px_5px_0px_rgba(26,26,27,1)]"
    >
        <svg viewBox="0 0 100 100" class="w-full h-full seal-spin" aria-hidden="true">
            <defs>
                <path
                    id="seal-text-circle"
                    d="M50,50 m-34,0 a34,34 0 1,1 68,0 a34,34 0 1,1 -68,0"
                ></path>
            </defs>
            <circle
                cx="50"
                cy="50"
                r="48"
                fill="var(--color-accent)"
                stroke="#1A1A1B"
                stroke-width="3.5"></circle>
            <circle
                cx="50"
                cy="50"
                r="24"
                fill="none"
                stroke="#1A1A1B"
                stroke-width="2"
                stroke-dasharray="3 4"></circle>
            <text
                fill="#1A1A1B"
                font-size="11.5"
                font-weight="700"
                letter-spacing="1.6"
                style="font-family: var(--font-heading);"
            >
                <textPath href="#seal-text-circle">
                    HAND-SHAKEN &#8226; FRESH DAILY &#8226;
                </textPath>
            </text>
            <path
                d="M50 41l2.6 5.3 5.9.9-4.3 4.1 1 5.9-5.2-2.8-5.2 2.8 1-5.9-4.3-4.1 5.9-.9z"
                fill="#1A1A1B"></path>
        </svg>
        <span class="sr-only">Hand-shaken, fresh daily</span>
    </div>

    <!-- Boba cup sticker -->
    <div
        class="absolute -bottom-5 -right-5 w-20 h-20 bg-secondary border-3 border-ink rounded-squircle flex items-center justify-center rotate-12 shadow-hard float-slow z-10"
    >
        <CupSoda size={38} strokeWidth={2.5} className="text-ink" />
    </div>

    <!-- Sparkle sticker -->
    <div
        class="absolute top-1/3 -right-8 w-16 h-16 bg-primary border-3 border-ink rounded-full flex items-center justify-center rotate-6 shadow-hard-sm float z-10"
        style="animation-delay: 0.5s;"
    >
        <Sparkles size={26} strokeWidth={2.5} className="text-white" fill="currentColor" />
    </div>

    <!-- The Cup SVG -->
    <svg
        viewBox="0 0 400 600"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-full h-auto drop-shadow-[10px_10px_0px_rgba(26,26,27,1)] transition-transform hover:scale-[1.02] duration-500 relative z-0"
        id="hero-cup-svg"
    >
        <!-- Liquid Defs -->
        <defs>
            <clipPath id="cup-clip">
                <path d="M100 500 L80 150 L320 150 L300 500 Z"></path>
            </clipPath>
            <linearGradient
                id="liquid-gradient"
                x1="0%"
                y1="0%"
                x2="0%"
                y2="100%"
            >
                <stop offset="0%" stop-color="#FF2DAB"></stop>
                <stop offset="100%" stop-color="#1A1A1B"></stop>
            </linearGradient>
            <!-- Glow filter -->
            <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
                <feMerge>
                    <feMergeNode in="coloredBlur"/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
        </defs>

        <!-- Cup Body Shadow (Hard) -->
        <!-- Removed for dropshadow on component -->

        <!-- Liquid Fill (Animated via JS) -->
        <g clip-path="url(#cup-clip)">
            <rect
                id="liquid-fill"
                x="0"
                y="600"
                width="400"
                height="600"
                fill="url(#liquid-gradient)"></rect>

            <!-- Bouncing Pearls -->
            <g id="pearls-container">
                <!-- Pearls will be added here or just simulated in CSS -->
                <circle
                    cx="150"
                    cy="480"
                    r="15"
                    fill="#1A1A1B"
                    class="pearl"
                    style="--d: 0s"></circle>
                <circle
                    cx="200"
                    cy="470"
                    r="15"
                    fill="#1A1A1B"
                    class="pearl"
                    style="--d: 0.2s"></circle>
                <circle
                    cx="250"
                    cy="475"
                    r="15"
                    fill="#1A1A1B"
                    class="pearl"
                    style="--d: 0.4s"></circle>
                <circle
                    cx="180"
                    cy="450"
                    r="15"
                    fill="#1A1A1B"
                    class="pearl"
                    style="--d: 0.1s"></circle>
                <circle
                    cx="220"
                    cy="455"
                    r="15"
                    fill="#1A1A1B"
                    class="pearl"
                    style="--d: 0.3s"></circle>
            </g>

            <!-- Ice Cubes (Jiggle) -->
            <g id="ice-cubes">
                <rect
                    x="180"
                    y="200"
                    width="40"
                    height="40"
                    rx="8"
                    fill="white"
                    fill-opacity="0.3"
                    class="ice"></rect>
                <rect
                    x="230"
                    y="250"
                    width="40"
                    height="40"
                    rx="8"
                    fill="white"
                    fill-opacity="0.3"
                    class="ice"></rect>
                <rect
                    x="130"
                    y="280"
                    width="40"
                    height="40"
                    rx="8"
                    fill="white"
                    fill-opacity="0.3"
                    class="ice"></rect>
            </g>
        </g>

        <!-- Cup Outline -->
        <path
            d="M100 500 L80 150 L320 150 L300 500 Z"
            stroke="#1A1A1B"
            stroke-width="12"
            stroke-linejoin="round"></path>
        <path
            d="M70 150 L330 150"
            stroke="#1A1A1B"
            stroke-width="12"
            stroke-linecap="round"></path>

        <!-- Lid -->
        <path
            d="M120 150 C120 100 280 100 280 150"
            stroke="#1A1A1B"
            stroke-width="12"
            fill="white"
            fill-opacity="0.5"></path>

        <!-- Straw -->
        <path
            d="M220 120 L240 20"
            stroke="#1A1A1B"
            stroke-width="15"
            stroke-linecap="round"></path>
        <path
            d="M220 120 L200 450"
            stroke="#1A1A1B"
            stroke-width="10"
            stroke-opacity="0.2"></path>
    </svg>
</div>

<style>
    .pearl {
        animation: pearl-bounce 2s infinite ease-in-out;
        animation-delay: var(--d);
        will-change: transform;
    }

    @keyframes pearl-bounce {
        0%,
        100% {
            transform: translateY(0) scale(1);
        }
        50% {
            transform: translateY(-30px) scale(1.1);
        }
    }

    .ice {
        animation: ice-jiggle 3s infinite ease-in-out;
        transform-origin: center;
    }

    @keyframes ice-jiggle {
        0%,
        100% {
            transform: rotate(0) translate(0);
        }
        25% {
            transform: rotate(5deg) translate(2px, -2px);
        }
        75% {
            transform: rotate(-5deg) translate(-2px, 2px);
        }
    }
    
    @keyframes pulse-slow {
        0%, 100% {
            opacity: 0.2;
            transform: scale(1);
        }
        50% {
            opacity: 0.3;
            transform: scale(1.1);
        }
    }
    
    .animate-pulse-slow {
        animation: pulse-slow 4s ease-in-out infinite;
    }

    .seal-spin {
        animation: seal-rotate 24s linear infinite;
    }

    @keyframes seal-rotate {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    
    /* Cup entrance animation */
    #hero-cup-svg {
        animation: cupEntrance 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    
    @keyframes cupEntrance {
        0% {
            opacity: 0;
            transform: translateY(40px) scale(0.9);
        }
        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .pearl,
        .ice,
        .float,
        .float-slow,
        .animate-pulse-slow,
        .seal-spin,
        #hero-cup-svg {
            animation: none;
        }
    }
</style>

<script>
    const liquidFill = document.getElementById("liquid-fill");

    function updateLiquidFill() {
        const scroll = window.scrollY;
        const maxScroll = 300;
        const fillPercent = Math.min(scroll / maxScroll, 1);

        // Fill stays at bottom (y=600) and moves up (to y=150)
        // y = 600 - (600 - 150) * fillPercent
        const yPos = 600 - 450 * fillPercent;

        if (liquidFill) {
            liquidFill.setAttribute("y", yPos.toString());
        }
    }

    window.addEventListener("scroll", updateLiquidFill);
    updateLiquidFill(); // Initial call
</script>
