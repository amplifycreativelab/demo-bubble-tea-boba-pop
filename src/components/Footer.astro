---
const baseUrl = import.meta.env.BASE_URL;

const suburbs = [
    "Central District",
    "Riverside",
    "Old Quarter",
    "East Market",
    "Harbor Walk",
    "Studio Row",
];

const socialLinks = [
    { name: "Instagram", href: "#" },
    { name: "TikTok", href: "#" },
    { name: "Twitter", href: "#" },
];
---

<footer class="bg-ink text-white pt-20 pb-10 px-4 mt-auto relative overflow-hidden">
    <!-- Atmospheric background elements -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-96 h-96 bg-primary/10 rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-80 h-80 bg-secondary/10 rounded-full blur-[100px] translate-x-1/3 translate-y-1/3"></div>
        <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-accent/5 rounded-full blur-[80px] -translate-x-1/2 -translate-y-1/2"></div>
    </div>
    
    <!-- Dot pattern overlay -->
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 30px 30px;"></div>
    
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
            <!-- Brand -->
            <div class="space-y-6">
                <a href={baseUrl} class="flex items-center gap-2 group">
                    <div
                        class="w-10 h-10 bg-primary border-3 border-white rounded-full flex items-center justify-center font-heading text-2xl text-ink shadow-hard-sm group-hover:-rotate-12 group-hover:scale-110 transition-all duration-300"
                    >
                        B
                    </div>
                    <span
                        class="font-heading text-3xl tracking-tighter text-white group-hover:text-primary transition-colors duration-300"
                        >BOBA POP!</span
                    >
                </a>
                <p class="font-body opacity-80 leading-relaxed">
                    The loudest boba experience. Hand-shaken, sticker-coated,
                    and 100% addictive.
                </p>
                <!-- Social Links -->
                <div class="flex gap-4 pt-2">
                    {socialLinks.map((link) => (
                        <a
                            href={link.href}
                            class="w-10 h-10 bg-white/10 border-2 border-white/20 rounded-full flex items-center justify-center hover:bg-primary hover:border-primary hover:text-ink transition-all duration-300 hover:scale-110 hover:-rotate-6"
                            aria-label={link.name}
                        >
                            {link.name === "Instagram" && (
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                                </svg>
                            )}
                            {link.name === "TikTok" && (
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                                </svg>
                            )}
                            {link.name === "Twitter" && (
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
                                </svg>
                            )}
                        </a>
                    ))}
                </div>
            </div>

            <!-- Quick Links -->
            <div class="space-y-6">
                <h4 class="font-heading text-2xl text-secondary relative inline-block">
                    EXPLORE
                    <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-secondary/30"></span>
                </h4>
                <ul class="space-y-3 font-body">
                    <li>
                        <a
                            href={`${baseUrl}menu`}
                            class="hover:text-primary transition-all duration-300 hover:translate-x-1 inline-block"
                            >Full Menu</a>
                    </li>
                    <li>
                        <a
                            href={`${baseUrl}specials`}
                            class="hover:text-primary transition-all duration-300 hover:translate-x-1 inline-block"
                            >Limited Drops</a>
                    </li>
                    <li>
                        <a
                            href={`${baseUrl}locations`}
                            class="hover:text-primary transition-all duration-300 hover:translate-x-1 inline-block"
                            >Find a Store</a>
                    </li>
                    <li>
                        <a
                            href={`${baseUrl}contact`}
                            class="hover:text-primary transition-all duration-300 hover:translate-x-1 inline-block"
                            >Catering</a>
                    </li>
                </ul>
            </div>

            <!-- Hours -->
            <div class="space-y-6">
                <h4 class="font-heading text-2xl text-accent relative inline-block">
                    HOURS
                    <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-accent/30"></span>
                </h4>
                <ul class="space-y-2 font-body text-sm opacity-80">
                    <li class="flex justify-between">
                        <span>Mon - Fri</span>
                        <span class="text-white">10am - 9pm</span>
                    </li>
                    <li class="flex justify-between">
                        <span>Saturday</span>
                        <span class="text-white">11am - 10pm</span>
                    </li>
                    <li class="flex justify-between">
                        <span>Sunday</span>
                        <span class="text-white">12pm - 8pm</span>
                    </li>
                </ul>
            </div>

            <!-- Cravings Map -->
            <div class="space-y-6">
                <h4 class="font-heading text-2xl text-primary uppercase relative inline-block">
                    Cravings Map
                    <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-primary/30"></span>
                </h4>
                <p class="font-body opacity-80 mb-4">
                    Popping up in your favorite suburbs:
                </p>
                <div class="flex flex-wrap gap-2">
                    {
                        suburbs.map((suburb) => (
                            <span class="bg-white/10 border border-white/20 px-3 py-1 rounded-full text-sm font-body hover:bg-primary hover:text-ink hover:border-primary transition-all duration-300 cursor-default hover:scale-105">
                                {suburb}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>

        <div
            class="pt-10 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4 font-body text-sm opacity-50"
        >
            <p>
                &copy; {new Date().getFullYear()} Boba Pop! All rights reserved.
            </p>
            <div class="flex gap-6">
                <a href={`${baseUrl}privacy`} class="hover:text-primary transition-colors hover:underline"
                    >Privacy Policy</a
                >
                <a href="#" class="hover:text-primary transition-colors hover:underline">Terms of Service</a>
            </div>
        </div>
    </div>
</footer>
